PORT=3000
JWT_SECRET=<вставь_случайный_ключ_минимум_64_символа>
ENCRYPTION_KEY=<вставь_64-символьный_HEX_ключ_для_AES-256>
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000

# Turso (облачная SQLite — сохраняется при деплое)
# Оставь пустым для локальной SQLite
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# Rate limiting
SOCKET_RATE_LIMIT=30
SOCKET_RATE_WINDOW=60000

# Pagination defaults
DEFAULT_PAGE_LIMIT=50
MAX_PAGE_LIMIT=200

# File upload limits
MAX_AVATAR_SIZE=5242880
MAX_POST_IMAGE_SIZE=10485760
MAX_MEDIA_SIZE=52428800
